# Domain — muss per A-Record auf die Server-IP zeigen
DOMAIN=admintoolbox.example.com

# Datenbank-Passwort — mindestens 20 zufällige Zeichen
DB_PASSWORD=aendere_mich_sicheres_passwort

# JWT-Secret — mindestens 32 zufällige Zeichen
# Generieren: openssl rand -hex 32
JWT_SECRET=aendere_mich_langer_zufaelliger_string_mindestens_32_zeichen
