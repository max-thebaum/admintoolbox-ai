{
  "name": "admintoolbox",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "start": "concurrently \"npm run dev\" \"npm run server\"",
    "setup": "node server/setup.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "node server/migrate.js",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "vite": "^5.4.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-forge": "^1.4.0",
    "pg": "^8.20.0",
    "quill": "^2.0.3",
    "sanitize-html": "^2.17.2"
  }
}
