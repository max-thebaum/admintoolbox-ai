# AdminToolbox — Environment Variables
# Kopiere diese Datei nach .env und fülle die Werte aus.
# Die .env Datei wird NICHT ins Git committed.

# Server-Port (Standard: 3001)
PORT=3001

# PostgreSQL Connection String
# Wird von Coolify automatisch befüllt wenn die DB dort angelegt wird
DATABASE_URL=postgresql://user:password@host:5432/admintoolbox

# JWT Secret — langer zufälliger String
# Generieren mit: openssl rand -base64 32
JWT_SECRET=ersetze-mich-mit-einem-langen-zufaelligen-string

# Umgebung
NODE_ENV=production
